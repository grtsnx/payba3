{
  "name": "payba3",
  "version": "0.0.1",
  "description": "One payment integration surface for many payment channels.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./llms.txt": "./llms.txt",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/lib",
    "assets/payba3-logo.svg",
    "README.md",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "llms.txt",
    "src/lib/**/*_llm.txt",
    "LICENSE",
    "SECURITY.md",
    "SUPPORT.md"
  ],
  "author": "",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grtsnx/payba3.git"
  },
  "bugs": {
    "url": "https://github.com/grtsnx/payba3/issues"
  },
  "homepage": "https://github.com/grtsnx/payba3#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "payments",
    "paystack",
    "safehaven",
    "seerbit",
    "opay",
    "mono",
    "monnify",
    "qoreid",
    "fintech",
    "ai-agents"
  ],
  "overrides": {
    "js-yaml": "4.2.0",
    "multer": "2.2.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "node node_modules/eslint/bin/eslint.js \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "node node_modules/eslint/bin/eslint.js \"{src,apps,libs,test}/**/*.ts\" --fix",
    "package:release": "scripts/package-release.sh",
    "pack:dry": "npm pack --dry-run",
    "prepack": "npm run lint && npm run test && npm run build",
    "test": "node node_modules/jest/bin/jest.js --passWithNoTests --runInBand",
    "test:package": "node scripts/package-smoke-test.mjs",
    "test:package:bun": "node scripts/package-smoke-test.mjs --installer bun",
    "test:providers": "node node_modules/jest/bin/jest.js --passWithNoTests --runInBand test/unit/lib",
    "test:watch": "node node_modules/jest/bin/jest.js --watch",
    "test:cov": "node node_modules/jest/bin/jest.js --coverage --runInBand",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "node node_modules/jest/bin/jest.js --config ./test/jest-e2e.json --runInBand"
  },
  "dependencies": {},
  "peerDependencies": {
    "@nestjs/common": ">=10 <12",
    "@nestjs/config": ">=3 <5",
    "@nestjs/core": ">=10 <12",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/testing": "^11.0.1",
    "@nestjs/throttler": "^6.5.0",
    "@scalar/nestjs-api-reference": "^1.2.3",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "helmet": "^8.2.0",
    "joi": "^18.2.1",
    "jest": "^30.0.0",
    "moment-timezone": "^0.6.2",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    },
    "rootDir": ".",
    "testRegex": "test/.*\\.spec\\.ts$",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      "/coverage/",
      "/\\.release/"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/dist",
      "<rootDir>/coverage",
      "<rootDir>/.release"
    ],
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s",
      "!src/**/*.module.ts",
      "!src/main.ts"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  }
}
