# Application Environment (development, production, test, provision)
NODE_ENV=development

# The port your application will run on
PORT=3000

# Safehaven MFB API configuration
# Use "sandbox" for https://api.sandbox.safehavenmfb.com
# Use "live" for https://api.safehavenmfb.com
SAFEHAVEN_ENVIRONMENT=sandbox
SAFEHAVEN_CLIENT_ID=
SAFEHAVEN_CLIENT_ASSERTION=

# Optional: override the base URL directly
# SAFEHAVEN_BASE_URL=https://api.sandbox.safehavenmfb.com
