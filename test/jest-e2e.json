{
  "moduleFileExtensions": ["js", "json", "ts"],
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1"
  },
  "rootDir": ".",
  "testEnvironment": "node",
  "testPathIgnorePatterns": ["/node_modules/", "/dist/", "/coverage/", "/\\.release/"],
  "modulePathIgnorePatterns": ["<rootDir>/../dist", "<rootDir>/../coverage", "<rootDir>/../.release"],
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
